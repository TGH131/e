{
  "redex" : {
    "passes" : [
      "RemoveUnreachablePass",
      "StripDebugInfoPass",
      "StringConcatenatorPass",
      "OptimizeEnumsPass",
      "ReBindRefsPass",
      "BridgePass",
      "ResultPropagationPass", # Run after BridgePass to avoid pattern matching conflicts
      "SynthPass",
      "FinalInlinePassV2",
      "DelSuperPass",
      "UnreferencedInterfacesPass",
      "SingleImplPass",
      "CommonSubexpressionEliminationPass", # Run once just before MethodInlinePass
      "MethodInlinePass",
      "PeepholePass",
      "ConstantPropagationPass",
      "CopyPropagationPass",
      "LocalDcePass",
      "DelInitPass",
      "RemoveUnreachablePass",
      "StaticReloPassV2",
      "RemoveEmptyClassesPass",
      "SingleImplPass",
      "RemoveGotosPass",
      "DedupBlocksPass",
      "UpCodeMotionPass",
      "SingleImplPass",
      "ReorderInterfacesDeclPass",
      "RemoveEmptyClassesPass",
      "ClassMergingPass",
      "ShortenSrcStringsPass",
      "CommonSubexpressionEliminationPass", # Run a second time after all method inlining is done
      "RegAllocPass",
      "CopyPropagationPass",
      "LocalDcePass",
      "DedupBlocksPass",
      "ReduceGotosPass", # This pass should come at the very end, after all other code transformations that might add gotos
      "CheckBreadcrumbsPass"
    ]
  },
  "FinalInlinePass" : {
    "propagate_static_finals": true,
    "replace_encodable_clinits": true
  },
  "inliner": {
    "throws": true,
    "multiple_callers": true,
    "blocklist": []
  },
  "RegAllocPass" : {
    "live_range_splitting": false
  },
  "CopyPropagationPass" : {
    "eliminate_const_literals": false,
    "full_method_analysis": true
  },
"StripDebugInfoPass" : {
    "drop_all_dbg_info" : true,
    "drop_local_variables" : true,
    "drop_line_numbers" : true,
    "drop_src_files" : true,
    "use_allowlist" : false,
    "cls_allowlist" : [],
    "method_allowlist" : [],
    "drop_prologue_end" : true,
    "drop_epilogue_begin" : true,
    "drop_all_dbg_info_if_empty" : true,
    "drop_synth_aggressive" : true,
    "drop_line_numbers_preceeding_safe" : true

  },
  "PeepholePass" : {
    "disabled_peepholes": [
      "Replace_PutGet",
      "Replace_PutGetWide",
      "Replace_PutGetObject",
      "Replace_PutGetShort",
      "Replace_PutGetChar",
      "Replace_PutGetByte",
      "Replace_PutGetBoolean"
    ]
  },
  "keep_packages": [
    "Lcom/fasterxml/jackson/",
    "Lcom/google/dexmaker/mockito/"
  ],
  "debug_info_kind": "no_custom_symbolication",
  "method_move_map" : "redex-moved-methods-map.txt",
  "string_sort_mode" : "class_order",
  "bytecode_sort_mode" : ["method_similarity_order", "class_order"],
  "ir_type_checker": {
    "run_after_each_pass" : false,
    "verify_moves" : false
  }
}
